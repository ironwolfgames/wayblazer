{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Wayblazer.Core/Wayblazer.Core.csproj",
            "src/Wayblazer.World/Wayblazer.World.csproj",
            "src/Wayblazer.Configurator/Wayblazer.Configurator.csproj",
            "src/Wayblazer.TilesetProcessor/Wayblazer.TilesetProcessor.csproj",
            "src/WFC.Utility/WFC.Utility.csproj",
            "lib/wave-function-collapse/src/WFC.Core/WFC.Core.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "Wayblazer API Documentation",
      "_appFooter": "Wayblazer - Generated with DocFX",
      "_enableSearch": true
    }
  }
}
